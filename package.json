{
  "name": "lyria",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:full": "pnpm run db:dev && pnpm run dev",
    "db:dev": "docker compose --env-file docker/.env.compose -f docker-compose.db-dev.yml up -d --build db",
    "db:dev:stop": "docker compose --env-file docker/.env.compose -f docker-compose.db-dev.yml down",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test": "vitest",
    "test:db": "node scripts/run-db-tests.js",
    "test:db:watch": "node scripts/run-db-tests.js --watch",
    "test:db:docker": "docker compose --env-file docker/.env.compose -f docker-compose.db-tests.yml up --build --abort-on-container-exit --exit-code-from db-tests",
    "test:db:perf:docker": "docker compose --env-file docker/.env.compose -f docker-compose.db-tests.yml run --build --rm db-tests pnpm vitest run src/lib/tests/server/search.performance.integration.test.ts --config vitest.db.config.ts",
    "test:db:perf:docker:full": "docker compose --env-file docker/.env.compose -f docker-compose.db-tests.yml run --build --rm -e SEARCH_PERF_INCLUDE_LARGE=1 -e SEARCH_PERF_TIMEOUT_MS=7200000 db-tests pnpm vitest run src/lib/tests/server/search.performance.integration.test.ts --config vitest.db.config.ts",
    "perf:plot": "tsx scripts/plot-search-benchmark.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "auth:generate": "pnpm exec better-auth generate --config ./auth.ts --output ./src/lib/server/db/auth-schema.ts --yes",
    "auth:migrate": "pnpm run db:migrate",
    "typesafe-i18n": "typesafe-i18n --no-watch",
    "typesafe-i18n:watch": "typesafe-i18n",
    "sync:cache": "tsx --env-file=.env.local scripts/sync-translation-cache.ts"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.3.0",
    "@fontsource/inter": "^5.2.8",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/greek-utils": "^1.2.2",
    "@types/node": "^25.3.3",
    "@vite-pwa/sveltekit": "^1.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "phosphor-svelte": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@types/youtube": "^0.1.2",
    "@upstash/redis": "^1.36.3",
    "@vercel/analytics": "^1.6.1",
    "better-auth": "^1.5.2",
    "cld3-asm": "^4.0.0",
    "deepl-node": "^1.24.0",
    "drizzle-orm": "^0.45.1",
    "emoji-regex": "^10.6.0",
    "es-hangul": "^2.3.8",
    "events": "^3.3.0",
    "greek-utils": "^1.3.0",
    "iuliia": "^0.8.2",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "pinyin-pro": "^3.28.0",
    "transliteration": "^2.6.1",
    "typesafe-i18n": "^5.27.1",
    "wanakana": "^5.3.1",
    "workbox-window": "^7.4.0"
  },
  "pnpm": {
    "overrides": {
      "cookie": "^0.7.0",
      "esbuild": "^0.27.3",
      "hono": "^4.12.4",
      "lodash": "^4.17.23",
      "nanoid": "^3.3.8",
      "serialize-javascript": "^7.0.4"
    }
  }
}
